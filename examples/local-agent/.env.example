# Required - ElizaOS agent needs an LLM for its own reasoning loop.
ANTHROPIC_API_KEY=

# Optional - customise logging. "debug" surfaces every NIP-90/Solana event.
LOG_LEVEL=info

# Optional overrides - normally ELISYM_* come from the character file,
# but env wins if both are set.
# ELISYM_RELAYS=wss://relay.damus.io,wss://nos.lol
# ELISYM_SOLANA_RPC_URL=https://api.devnet.solana.com
