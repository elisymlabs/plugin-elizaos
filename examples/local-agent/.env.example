# Required - ElizaOS agent needs an LLM for its own reasoning loop.
ANTHROPIC_API_KEY=

# Pin Claude model IDs. Haiku 4.5 is the latest 2025 Haiku; the plugin-anthropic
# default (claude-3-5-haiku-20241022) has been retired by Anthropic and causes
# "model: claude-3-5-haiku-20241022" errors when the provider processes a job.
ANTHROPIC_SMALL_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_LARGE_MODEL=claude-haiku-4-5-20251001

# Optional - customise logging. "debug" surfaces every NIP-90/Solana event.
LOG_LEVEL=info

# Optional overrides - normally ELISYM_* come from the character file,
# but env wins if both are set.
# ELISYM_RELAYS=wss://relay.damus.io,wss://nos.lol
# ELISYM_SOLANA_RPC_URL=https://api.devnet.solana.com
